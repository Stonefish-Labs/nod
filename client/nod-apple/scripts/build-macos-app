#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "${SCRIPT_DIR}/.." && pwd)"

# Pinned to Release: this script is the macOS test build. A Debug bundle from
# Xcode shares the bundle id + state dir, so two builds register as the same
# device and fight over notifications/decisions. Keeping this Release-only means
# the script can never produce that second build. (Run the iOS scheme in Xcode
# for iOS dev — different platform, no collision.)
CONFIGURATION="Release"
BUILD_DIR="${NOD_MAC_BUILD_DIR:-${ROOT_DIR}/build/DerivedData/Build}"
PRODUCTS_DIR="${BUILD_DIR}/Products"
CONFIGURATION_BUILD_DIR="${PRODUCTS_DIR}/${CONFIGURATION}"
APP_PATH="${CONFIGURATION_BUILD_DIR}/Nod.app"
MARKETING_VERSION="${NOD_MAC_MARKETING_VERSION:-1.0}"
BUILD_NUMBER="${NOD_MAC_BUILD_NUMBER:-$(date -u +%Y%m%d%H%M)}"

if [[ -z "${DEVELOPER_DIR:-}" && -d /Applications/Xcode.app/Contents/Developer ]]; then
  export DEVELOPER_DIR=/Applications/Xcode.app/Contents/Developer
fi

# Regenerate the embedded Rust runtime first. nod_client_ffiFFI.xcframework is a
# prebuilt binary, so without this an edit to nod-client-core silently runs old
# code in the app (e.g. a missing wire field that blanks the UI). cargo caches,
# so this is cheap when nod-client-core is unchanged. Set SKIP_FFI_REBUILD=1 to
# skip (e.g. a pure-Swift iteration).
if [[ "${SKIP_FFI_REBUILD:-0}" != "1" ]]; then
  echo "==> Regenerating nod_client_ffiFFI.xcframework from current Rust source"
  "${SCRIPT_DIR}/build-nod-client-ffi.sh"
  echo
fi

echo "Building Nod macOS app bundle (${CONFIGURATION})"
echo "Version: ${MARKETING_VERSION} (${BUILD_NUMBER})"
echo "Output: ${APP_PATH}"
echo

CODE_SIGNING_ALLOWED_VALUE="${CODE_SIGNING_ALLOWED:-YES}"

build_app() {
  local code_signing_allowed="$1"
  local command=(xcodebuild)
  if [[ "${ALLOW_PROVISIONING_UPDATES:-YES}" == "YES" && "${code_signing_allowed}" == "YES" ]]; then
    command+=("-allowProvisioningUpdates")
  fi
  "${command[@]}" \
    -project "${ROOT_DIR}/Nod.xcodeproj" \
    -target NodMac \
    -configuration "${CONFIGURATION}" \
    CODE_SIGNING_ALLOWED="${code_signing_allowed}" \
    MARKETING_VERSION="${MARKETING_VERSION}" \
    CURRENT_PROJECT_VERSION="${BUILD_NUMBER}" \
    CONFIGURATION_BUILD_DIR="${CONFIGURATION_BUILD_DIR}" \
    OBJROOT="${BUILD_DIR}/Intermediates.noindex" \
    SYMROOT="${PRODUCTS_DIR}" \
    build
}

if ! build_app "${CODE_SIGNING_ALLOWED_VALUE}"; then
  if [[ -z "${CODE_SIGNING_ALLOWED:-}" && "${CODE_SIGNING_ALLOWED_VALUE}" == "YES" ]]; then
    echo
    echo "warning: signed build failed; falling back to an unsigned local build." >&2
    echo "warning: the fallback will be signed manually if a local Apple Development certificate is available." >&2
    echo
    CODE_SIGNING_ALLOWED_VALUE="NO"
    build_app "${CODE_SIGNING_ALLOWED_VALUE}"
  else
    exit 1
  fi
fi

if [[ ! -x "${APP_PATH}/Contents/MacOS/Nod" ]]; then
  echo "error: expected app executable was not produced: ${APP_PATH}/Contents/MacOS/Nod" >&2
  exit 1
fi

signing_identity() {
  security find-identity -v -p codesigning 2>/dev/null \
    | awk -F '"' '/Apple Development:/ { print $2; exit }'
}

if ! codesign --verify --verbose=2 "${APP_PATH}" >/dev/null 2>&1; then
  IDENTITY="$(signing_identity)"
  if [[ -n "${IDENTITY}" ]]; then
    codesign --force --deep --options runtime --sign "${IDENTITY}" "${APP_PATH}" >/dev/null 2>&1 || true
  else
    codesign --force --deep --sign - "${APP_PATH}" >/dev/null 2>&1 || true
  fi
fi
if ! codesign --verify --verbose=2 "${APP_PATH}" >/dev/null 2>&1; then
  echo "warning: ${APP_PATH} is not signed; UNUserNotificationCenter and Keychain may reject the bundle." >&2
fi

echo
echo "Built app bundle:"
echo "  ${APP_PATH}"
echo "  version ${MARKETING_VERSION} (${BUILD_NUMBER})"
echo
echo "Open it with:"
echo "  open \"${APP_PATH}\""
echo
echo "If the UI still looks stale, quit any running Nod process before reopening this app."
