#!/usr/bin/env bash
# Release pipeline for the macOS app: Developer ID signing, notarization,
# stapling, and a notarized DMG ready for the GitHub release.
#
#   scripts/release-macos [VERSION]
#
# One-time setup (see docs/APPLE.md "Release builds"):
#   - a "Developer ID Application" certificate in the login keychain
#   - notary credentials stored as a keychain profile:
#       xcrun notarytool store-credentials nod-notary \
#         --apple-id you@example.com --team-id TEAMID
#
# `build-macos-app` stays the day-to-day dev build (Apple Development /
# ad-hoc); this script is the only path that produces a publishable DMG.
#
# Signing note: the app is signed WITHOUT entitlements, matching the verified
# dev build. The App Attest entitlement in NodMac.entitlements is restricted
# (it would force Developer ID provisioning-profile machinery) and macOS
# enrollment treats attestation as best-effort — the server's report-only
# mode accepts enrollments without it.
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
VERSION="${1:-${NOD_MAC_MARKETING_VERSION:-1.0.0}}"
NOTARY_PROFILE="${NOD_NOTARY_PROFILE:-nod-notary}"
DIST_DIR="${ROOT_DIR}/build/release"
APP_PATH="${ROOT_DIR}/build/DerivedData/Build/Products/Release/Nod.app"
DMG_PATH="${DIST_DIR}/Nod-${VERSION}.dmg"

step() { printf '\n==> %s\n' "$*"; }

step "Resolving Developer ID identity"
IDENTITY="$(security find-identity -v -p codesigning 2>/dev/null \
  | awk -F '"' '/Developer ID Application:/ { print $2; exit }')"
if [[ -z "${IDENTITY}" ]]; then
  echo "error: no 'Developer ID Application' certificate in the keychain." >&2
  echo "       Create one (Xcode → Settings → Accounts → Manage Certificates" >&2
  echo "       or developer.apple.com) — see docs/APPLE.md 'Release builds'." >&2
  exit 1
fi
echo "Signing as: ${IDENTITY}"

if ! xcrun notarytool history --keychain-profile "${NOTARY_PROFILE}" >/dev/null 2>&1; then
  echo "error: notary keychain profile '${NOTARY_PROFILE}' is missing." >&2
  echo "       xcrun notarytool store-credentials ${NOTARY_PROFILE} \\" >&2
  echo "         --apple-id you@example.com --team-id TEAMID" >&2
  exit 1
fi

step "Building Nod.app ${VERSION} (unsigned; this script signs)"
NOD_MAC_MARKETING_VERSION="${VERSION}" CODE_SIGNING_ALLOWED=NO \
  "${ROOT_DIR}/scripts/build-macos-app"

step "Signing inside-out with hardened runtime"
# Embedded frameworks/dylibs first, then the bundle itself.
while IFS= read -r -d '' nested; do
  codesign --force --timestamp --options runtime --sign "${IDENTITY}" "${nested}"
done < <(find "${APP_PATH}/Contents/Frameworks" \
           \( -name "*.framework" -o -name "*.dylib" \) -depth 1 -print0 2>/dev/null || true)
codesign --force --timestamp --options runtime --sign "${IDENTITY}" "${APP_PATH}"
codesign --verify --deep --strict --verbose=2 "${APP_PATH}"

step "Notarizing the app"
mkdir -p "${DIST_DIR}"
APP_ZIP="${DIST_DIR}/Nod-${VERSION}.zip"
ditto -c -k --keepParent "${APP_PATH}" "${APP_ZIP}"
if ! xcrun notarytool submit "${APP_ZIP}" --keychain-profile "${NOTARY_PROFILE}" --wait; then
  echo "error: notarization was not accepted; fetch details with:" >&2
  echo "       xcrun notarytool log <submission-id> --keychain-profile ${NOTARY_PROFILE}" >&2
  exit 1
fi
xcrun stapler staple "${APP_PATH}"
rm -f "${APP_ZIP}"

step "Building the DMG"
STAGING="$(mktemp -d)"
trap 'rm -rf "${STAGING}"' EXIT
cp -R "${APP_PATH}" "${STAGING}/"
ln -s /Applications "${STAGING}/Applications"
rm -f "${DMG_PATH}"
hdiutil create -volname "Nod" -srcfolder "${STAGING}" -ov -format UDZO "${DMG_PATH}" >/dev/null

step "Signing, notarizing, and stapling the DMG"
codesign --force --timestamp --sign "${IDENTITY}" "${DMG_PATH}"
if ! xcrun notarytool submit "${DMG_PATH}" --keychain-profile "${NOTARY_PROFILE}" --wait; then
  echo "error: DMG notarization was not accepted (see notarytool log)." >&2
  exit 1
fi
xcrun stapler staple "${DMG_PATH}"

step "Gatekeeper verification"
spctl --assess --type execute --verbose=2 "${APP_PATH}"
spctl --assess --type open --context context:primary-signature --verbose=2 "${DMG_PATH}"

step "Checksum"
shasum -a 256 "${DMG_PATH}" | tee "${DMG_PATH}.sha256"

echo
echo "Notarized DMG ready:"
echo "  ${DMG_PATH}"
echo
echo "Upload it to the draft release and append its checksum to SHA256SUMS:"
echo "  gh release upload v${VERSION} \"${DMG_PATH}\""
