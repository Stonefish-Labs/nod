#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage: scripts/testflight-ios [--archive-only] [--external] [--help]

Archives NodIOS and uploads it to App Store Connect for TestFlight.

Required environment:
  APP_STORE_CONNECT_API_KEY_ID       App Store Connect API key ID, inferred from AuthKey_<key-id>.p8 if omitted
  APP_STORE_CONNECT_API_ISSUER_ID    App Store Connect API issuer ID
  APP_STORE_CONNECT_API_KEY_PATH     Path to AuthKey_<key-id>.p8

Aliases are also accepted:
  ASC_API_KEY_ID
  ASC_API_ISSUER_ID
  ASC_API_KEY_PATH

Optional environment:
  APP_STORE_CONNECT_API_PRIVATE_KEY  Raw .p8 contents, used if no key path is set
  NOD_APPLE_TEAM_ID                 Defaults to Y734633UDM
  NOD_IOS_BUNDLE_ID                 Defaults to com.batteryshark.Boop
  NOD_MARKETING_VERSION             Defaults to 1.0
  NOD_BUILD_NUMBER                  Defaults to UTC yyyymmddHHMM
  NOD_TESTFLIGHT_INTERNAL_ONLY      Defaults to true
  NOD_ARCHIVE_PATH                  Defaults under /private/tmp/nod-testflight
  NOD_EXPORT_PATH                   Defaults under /private/tmp/nod-testflight
  DEVELOPER_DIR                      Defaults to /Applications/Xcode.app/Contents/Developer

Flags:
  --archive-only   Build the signed archive but skip upload.
  --external       Allow this build to be used for external TestFlight later.
EOF
}

archive_only=false
internal_only="${NOD_TESTFLIGHT_INTERNAL_ONLY:-true}"

for arg in "$@"; do
  case "$arg" in
    --archive-only)
      archive_only=true
      ;;
    --external)
      internal_only=false
      ;;
    --help|-h)
      usage
      exit 0
      ;;
    *)
      echo "Unknown argument: $arg" >&2
      usage >&2
      exit 2
      ;;
  esac
done

case "$(printf '%s' "$internal_only" | tr '[:upper:]' '[:lower:]')" in
  true|yes|1)
    internal_only=true
    ;;
  false|no|0)
    internal_only=false
    ;;
  *)
    echo "NOD_TESTFLIGHT_INTERNAL_ONLY must be true or false." >&2
    exit 2
    ;;
esac

source_env_file() {
  local env_file="$1"
  if [[ ! -f "$env_file" ]]; then
    return
  fi

  set -a
  # shellcheck disable=SC1091
  source "$env_file"
  set +a
}

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
source_env_file "$ROOT_DIR/.env"
source_env_file "$ROOT_DIR/secrets/secrets.env"

PROJECT_PATH="$ROOT_DIR/Nod.xcodeproj"
SCHEME="NodIOS"
CONFIGURATION="Release"

export DEVELOPER_DIR="${DEVELOPER_DIR:-/Applications/Xcode.app/Contents/Developer}"

TEAM_ID="${NOD_APPLE_TEAM_ID:-Y734633UDM}"
BUNDLE_ID="${NOD_IOS_BUNDLE_ID:-com.batteryshark.Boop}"
MARKETING_VERSION="${NOD_MARKETING_VERSION:-1.0}"
BUILD_NUMBER="${NOD_BUILD_NUMBER:-$(date -u +%Y%m%d%H%M)}"
WORK_DIR="${NOD_TESTFLIGHT_WORK_DIR:-/private/tmp/nod-testflight}"
DERIVED_DATA_PATH="${NOD_DERIVED_DATA_PATH:-$WORK_DIR/DerivedData}"
ARCHIVE_PATH="${NOD_ARCHIVE_PATH:-$WORK_DIR/NodIOS-$BUILD_NUMBER.xcarchive}"
EXPORT_PATH="${NOD_EXPORT_PATH:-$WORK_DIR/export-$BUILD_NUMBER}"

API_KEY_ID="${APP_STORE_CONNECT_API_KEY_ID:-${ASC_API_KEY_ID:-}}"
API_ISSUER_ID="${APP_STORE_CONNECT_API_ISSUER_ID:-${ASC_API_ISSUER_ID:-}}"
API_KEY_PATH="${APP_STORE_CONNECT_API_KEY_PATH:-${ASC_API_KEY_PATH:-}}"
TMP_API_KEY_PATH=""
EXPORT_OPTIONS_PLIST=""

cleanup() {
  if [[ -n "$TMP_API_KEY_PATH" ]]; then
    rm -f "$TMP_API_KEY_PATH"
  fi
  if [[ -n "$EXPORT_OPTIONS_PLIST" ]]; then
    rm -f "$EXPORT_OPTIONS_PLIST"
  fi
}
trap cleanup EXIT

if [[ -z "$API_KEY_PATH" ]]; then
  if [[ -z "${APP_STORE_CONNECT_API_PRIVATE_KEY:-}" ]]; then
    echo "Missing App Store Connect API key." >&2
    echo "Set APP_STORE_CONNECT_API_KEY_PATH or APP_STORE_CONNECT_API_PRIVATE_KEY." >&2
    exit 2
  fi
  TMP_API_KEY_PATH="$(mktemp /private/tmp/nod-asc-key.XXXXXX.p8)"
  printf '%b\n' "$APP_STORE_CONNECT_API_PRIVATE_KEY" > "$TMP_API_KEY_PATH"
  chmod 600 "$TMP_API_KEY_PATH"
  API_KEY_PATH="$TMP_API_KEY_PATH"
fi

if [[ -n "$API_KEY_PATH" && "$API_KEY_PATH" != /* ]]; then
  API_KEY_PATH="$ROOT_DIR/$API_KEY_PATH"
fi

if [[ ! -f "$API_KEY_PATH" ]]; then
  echo "App Store Connect API key file does not exist: $API_KEY_PATH" >&2
  exit 2
fi

if [[ -z "$API_KEY_ID" ]]; then
  key_basename="$(basename "$API_KEY_PATH")"
  if [[ "$key_basename" =~ ^AuthKey_([A-Z0-9]+)\.p8$ ]]; then
    API_KEY_ID="${BASH_REMATCH[1]}"
  fi
fi

if [[ -z "$API_KEY_ID" || -z "$API_ISSUER_ID" ]]; then
  echo "Missing App Store Connect API credentials." >&2
  echo "Set APP_STORE_CONNECT_API_ISSUER_ID and, if it cannot be inferred from the key filename, APP_STORE_CONNECT_API_KEY_ID." >&2
  exit 2
fi

mkdir -p "$WORK_DIR" "$EXPORT_PATH"

EXPORT_OPTIONS_PLIST="$(mktemp /private/tmp/nod-export-options.XXXXXX.plist)"
cat > "$EXPORT_OPTIONS_PLIST" <<EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>destination</key>
  <string>upload</string>
  <key>method</key>
  <string>app-store-connect</string>
  <key>signingStyle</key>
  <string>automatic</string>
  <key>teamID</key>
  <string>$TEAM_ID</string>
  <key>manageAppVersionAndBuildNumber</key>
  <false/>
  <key>stripSwiftSymbols</key>
  <true/>
  <key>uploadSymbols</key>
  <true/>
  <key>testFlightInternalTestingOnly</key>
  <$internal_only/>
</dict>
</plist>
EOF

echo "Archiving NodIOS $MARKETING_VERSION ($BUILD_NUMBER)"
echo "Bundle ID: $BUNDLE_ID"
echo "Team ID:   $TEAM_ID"

xcodebuild \
  -project "$PROJECT_PATH" \
  -scheme "$SCHEME" \
  -configuration "$CONFIGURATION" \
  -destination "generic/platform=iOS" \
  -archivePath "$ARCHIVE_PATH" \
  -derivedDataPath "$DERIVED_DATA_PATH" \
  -allowProvisioningUpdates \
  -authenticationKeyPath "$API_KEY_PATH" \
  -authenticationKeyID "$API_KEY_ID" \
  -authenticationKeyIssuerID "$API_ISSUER_ID" \
  DEVELOPMENT_TEAM="$TEAM_ID" \
  PRODUCT_BUNDLE_IDENTIFIER="$BUNDLE_ID" \
  MARKETING_VERSION="$MARKETING_VERSION" \
  CURRENT_PROJECT_VERSION="$BUILD_NUMBER" \
  CODE_SIGN_STYLE=Automatic \
  clean archive

if [[ "$archive_only" == true ]]; then
  echo "Archive complete: $ARCHIVE_PATH"
  exit 0
fi

echo "Uploading archive to App Store Connect for TestFlight"
if ! xcodebuild \
    -exportArchive \
    -archivePath "$ARCHIVE_PATH" \
    -exportPath "$EXPORT_PATH" \
    -exportOptionsPlist "$EXPORT_OPTIONS_PLIST" \
    -allowProvisioningUpdates \
    -authenticationKeyPath "$API_KEY_PATH" \
    -authenticationKeyID "$API_KEY_ID" \
    -authenticationKeyIssuerID "$API_ISSUER_ID"; then
  latest_distribution_log="$(ls -td "${TMPDIR:-/tmp}"/NodIOS_*.xcdistributionlogs 2>/dev/null | head -n 1 || true)"
  if [[ -n "$latest_distribution_log" ]]; then
    missing_app_line="$(grep -R "DistributionAppRecordProviderError.missingApp" "$latest_distribution_log" 2>/dev/null | head -n 1 || true)"
    if [[ -n "$missing_app_line" ]]; then
      echo "" >&2
      echo "App Store Connect could not find an app record for bundle ID: $BUNDLE_ID" >&2
      echo "Create the app in App Store Connect, or set NOD_IOS_BUNDLE_ID to the bundle ID of the existing app." >&2
    fi
    echo "Distribution logs: $latest_distribution_log" >&2
  fi
  exit 1
fi

echo "Upload submitted. Apple will process the build before it appears in TestFlight."
